# ============================================================================
# Spine GraphRAG v1.25.0 - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your API keys
# cp .env.example .env
#
# Version: 1.24.1 (2026-03-01)
# Features: Ontology-Based GraphRAG, Multi-entity IS_A, Graph Traversal Search

# ============================================================================
# LLM API Keys (Required)
# ============================================================================

# Anthropic API Key for Claude (Primary LLM)
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# OpenAI API Key (REQUIRED for vector search & import - v1.14.26+)
# Uses: text-embedding-3-large (3072 dimensions)
# Without this key, vector search and paper import will fail
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx

# Gemini API Key (Optional - for fallback)
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ============================================================================
# LLM Provider Configuration
# ============================================================================

# Primary LLM Provider: "claude" (recommended) or "gemini"
LLM_PROVIDER=claude

# Claude Model Selection
# Options: claude-haiku-4-5-20251001 (fast, cost-effective)
#          claude-sonnet-4-5-20250929 (higher quality)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Fallback Model (auto-switch when token limit exceeded)
CLAUDE_FALLBACK_MODEL=claude-sonnet-4-5-20250929

# Auto Fallback: "true" or "false"
CLAUDE_AUTO_FALLBACK=true

# Gemini Model (when LLM_PROVIDER=gemini)
# Options: gemini-2.5-flash, gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash

# ============================================================================
# Neo4j Database Configuration
# ============================================================================

# Neo4j Connection (see docker-compose.yml NEO4J_AUTH for default)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<change-me>
NEO4J_DATABASE=neo4j

# Neo4j Bolt Thread Pool (v1.14.23)
# Maximum concurrent connections the Bolt connector can handle
# Recommended: PUBMED_MAX_CONCURRENT * 4 or higher
# Note: Requires docker-compose restart after change
NEO4J_BOLT_THREAD_POOL_SIZE=40

# ============================================================================
# PubMed/NCBI Configuration (Optional - for citation enrichment)
# ============================================================================

# NCBI Contact Email (Required for PubMed API)
# Used for: Citation lookup, paper metadata enrichment
NCBI_EMAIL=your@email.com

# NCBI API Key (Optional - increases rate limit from 3 to 10 req/sec)
# Get your key: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# PubMed Import Concurrency (v1.14.23)
# Maximum concurrent papers to process during bulk import
# Range: 1-10, Default: 5
# - 1: Sequential (safest, slowest)
# - 5: Recommended (balanced speed and stability)
# - 10: Maximum (fast but higher Neo4j/LLM load)
PUBMED_MAX_CONCURRENT=5

# ============================================================================
# Concurrency Configuration (v1.23.4)
# ============================================================================

# LLM API Maximum Concurrent Calls
# Controls Claude/Gemini API simultaneous requests
# Range: 1-20, Default: 5
# - 5: Safe for most API tiers (recommended)
# - 10: For higher-tier API plans
# - 20: Maximum (requires high rate limits)
# Note: Anthropic Haiku allows ~50 RPM on standard tier
LLM_MAX_CONCURRENT=5

# ============================================================================
# Embedding Configuration
# ============================================================================

# Embedding Model (OpenAI text-embedding-3-large, 3072 dimensions)
# Used for: Vector search, chunk embeddings, abstract embeddings
EMBEDDING_MODEL=text-embedding-3-large

# ============================================================================
# SNOMED-CT API Configuration (Optional)
# ============================================================================

# SNOMED CT Terminology Server API
# Used for: Real-time SNOMED concept lookup, validation
# Public server: https://snowstorm.ihtsdotools.org (no key required)
SNOMED_API_URL=https://snowstorm.ihtsdotools.org
SNOMED_API_KEY=

# ============================================================================
# Feature Flags (Optional)
# ============================================================================

# Enable cited paper abstract analysis (v1.6+)
# When true, LLM analyzes abstracts of cited papers for entity extraction
ANALYZE_CITED_ABSTRACTS=true
